{
  "name": "@sitelintpackages/mongoose-cache",
  "version": "1.1.2",
  "description": "MongoDB-based cache for Mongoose queries with TTL and invalidation support",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "prebuild": "node build/ctlint/ctlint.cjs start --config ./ctlint.json --format-changed-files",
    "build": "shx rm -rf dist && tsc -p .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src/ --fix",
    "test": "node --require ts-node/register --test '__tests__/**/*.spec.ts'",
    "validate": "npm run ctlint",
    "ctlint": "node build/ctlint/ctlint.cjs start --config ./ctlint.json",
    "release": "release-it --config release-it.json"
  },
  "peerDependencies": {
    "mongoose": ">=8.0.0"
  },
  "devDependencies": {
    "@types/node": ">=26.0.0",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "eslint": ">=10.5.0",
    "eslint-config-prettier": ">=10.1.8",
    "globals": "17.7.0",
    "mongoose": ">=9.7.2",
    "colors": ">=1.4.0",
    "glob-all": ">=3.3.1",
    "is-utf8": ">=0.2.1",
    "release-it": "20.2.0",
    "prettier": ">=3.8.4",
    "shelljs": ">=0.10.0",
    "shx": ">=0.4.0",
    "ts-node": ">=10.9.2",
    "typescript": ">=6.0.3"
  },
  "keywords": [
    "mongoose",
    "cache",
    "mongodb",
    "query-cache",
    "aggregation-cache",
    "ttl"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sitelint/mongoose-cache.git"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
